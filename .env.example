# ─── NextAuth ──────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_32_chars_min
# Local dev → http://localhost:3000
# Production → https://tutor.theaihublab.com
NEXTAUTH_URL=http://localhost:3000

# ─── Email magic-link sign-in (NextAuth EmailProvider) ─────
# SMTP connection string, e.g.
#   smtp://apikey:SG.xxx@smtp.sendgrid.net:587
#   smtp://resend:re_xxx@smtp.resend.com:465
#   smtp://postmaster%40mg.yourdomain.com:pwd@smtp.mailgun.org:587
EMAIL_SERVER=smtp://user:pass@smtp.yourprovider.com:587
EMAIL_FROM=noreply@theaihublab.com

# ─── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── News & Content APIs ────────────────────────────────────
NEWSAPI_KEY=your_newsapi_org_key

# ─── AI (Google Gemini) ─────────────────────────────────────
# Get a key at  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── App URL (production) ───────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tutor.theaihublab.com

# ─── CRON (optional; protects /api/refresh on Vercel) ──────
CRON_SECRET=any_long_random_string
